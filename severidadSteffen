//Verificar calidad de clasificacion
var test = fireClass.sampleRegions({
  collection: testing,
  properties: ['burned'],
  scale: 10
});
var kappa_train = classifier.confusionMatrix().kappa();
var testConfusionMatrix = test.errorMatrix('burned', 'classification');
var kappa_test = testConfusionMatrix.kappa();

