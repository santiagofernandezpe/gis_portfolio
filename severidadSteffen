var testing = datasamples.filterMetadata('random', 'not_less_than', 0.5);
//Configurar clasificador
training = clippedImage.sampleRegions({
  collection: training,
  properties: ['burned'],
  scale: 10
});
var classifier = ee.Classifier.smileRandomForest(75) 
    .train({
      features: training,
      classProperty: 'burned',
      inputProperties: band
    });
