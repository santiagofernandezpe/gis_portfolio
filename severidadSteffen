// Cálculo de severidad incendio DIC 2021 vs. APR 2022 
// NBR=(NIR-SWIR)/(NIR+SWIR)
var AntesNIR = imgAntes.select("B8");
var AntesSWIR = imgAntes.select("B11");
var DespuesNIR = imgDespues2022.select("B8");
